{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug-ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/debug-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TES_BUILD_PYTHON_BINDINGS": "OFF"
      }
    },
    {
      "name": "debug-msvc",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/debug-msvc",
      "cacheVariables": {
        "TES_BUILD_PYTHON_BINDINGS": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "debug-ninja-python",
      "inherits": "debug-ninja",
      "binaryDir": "${sourceDir}/out/build/debug-ninja-python",
      "cacheVariables": {
        "TES_BUILD_PYTHON_BINDINGS": "ON"
      }
    },
    {
      "name": "debug-msvc-python",
      "inherits": "debug-msvc",
      "binaryDir": "${sourceDir}/out/build/debug-msvc-python",
      "cacheVariables": {
        "TES_BUILD_PYTHON_BINDINGS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug-ninja",
      "configurePreset": "debug-ninja"
    },
    {
      "name": "debug-msvc",
      "configurePreset": "debug-msvc",
      "configuration": "Debug"
    },
    {
      "name": "debug-ninja-python",
      "configurePreset": "debug-ninja-python"
    },
    {
      "name": "debug-msvc-python",
      "configurePreset": "debug-msvc-python",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "debug-ninja",
      "configurePreset": "debug-ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug-msvc",
      "configurePreset": "debug-msvc",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug-ninja-python",
      "configurePreset": "debug-ninja-python",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug-msvc-python",
      "configurePreset": "debug-msvc-python",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
