#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME="$(basename "$0")"

is_windows_shell() {
  case "$(uname -s 2>/dev/null || echo unknown)" in
    MINGW*|MSYS*|CYGWIN*) return 0 ;;
    *) return 1 ;;
  esac
}

default_preset() {
  if is_windows_shell; then
    printf '%s\n' "debug-msvc"
  else
    printf '%s\n' "debug-ninja"
  fi
}

python_preset() {
  if is_windows_shell; then
    printf '%s\n' "release-msvc-python"
  else
    printf '%s\n' "debug-ninja-python"
  fi
}

python_ext_dir() {
  if is_windows_shell; then
    printf '%s\n' "Release"
  else
    printf '%s\n' ""
  fi
}

is_windows_store_python_alias() {
  local candidate="$1"
  case "${candidate}" in
    */Microsoft/WindowsApps/python|*/Microsoft/WindowsApps/python.exe|\
    */Microsoft/WindowsApps/python3|*/Microsoft/WindowsApps/python3.exe|\
    *\\Microsoft\\WindowsApps\\python|*\\Microsoft\\WindowsApps\\python.exe|\
    *\\Microsoft\\WindowsApps\\python3|*\\Microsoft\\WindowsApps\\python3.exe)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

probe_python_executable() {
  local candidate="$1"
  if [[ -z "${candidate}" ]] || is_windows_store_python_alias "${candidate}"; then
    return 1
  fi

  "${candidate}" -c 'import sys' 2>/dev/null || return 1
  printf '%s\n' "${candidate}"
}

probe_py_launcher() {
  if ! is_windows_shell || ! command -v py >/dev/null 2>&1; then
    return 1
  fi

  py -3 -c 'import sys; print(sys.executable)' 2>/dev/null
}

resolve_python() {
  local candidate

  if [[ -n "${TES_PYTHON:-}" ]]; then
    probe_python_executable "${TES_PYTHON}" && return 0
  fi

  for candidate in \
    "$(command -v python3 || true)" \
    "$(command -v python || true)"
  do
    probe_python_executable "${candidate}" && return 0
  done

  probe_py_launcher && return 0

  echo "real python3/python interpreter not found in PATH" >&2
  return 1
}

run_core_check() {
  local preset="${1:-$(default_preset)}"
  echo "[TES] Configure preset: ${preset}"
  cmake --preset "${preset}"
  echo "[TES] Build preset: ${preset}"
  cmake --build --preset "${preset}"
  echo "[TES] Test preset: ${preset}"
  ctest --preset "${preset}"
}

run_python_check() {
  local preset="$1"
  local build_config="${2:-}"
  local pybin
  if ! pybin="$(resolve_python)"; then
    exit 1
  fi

  local cmake_args=(--preset "${preset}" -DPython3_EXECUTABLE="${pybin}")
  if is_windows_shell; then
    local pybind11_dir
    pybind11_dir="$("${pybin}" -m pybind11 --cmakedir)"
    cmake_args+=(-Dpybind11_DIR="${pybind11_dir}")
  fi

  echo "[TES] Configure Python bindings preset: ${preset}"
  cmake "${cmake_args[@]}"

  echo "[TES] Build Python bindings preset: ${preset}"
  if [[ -n "${build_config}" ]]; then
    cmake --build --preset "${preset}" --config "${build_config}"
  else
    cmake --build --preset "${preset}"
  fi

  local ext_dir
  ext_dir="$(python_ext_dir)"
  local module_path="out/build/${preset}/engine"
  if [[ -n "${ext_dir}" ]]; then
    module_path="${module_path}/${ext_dir}"
  fi

  echo "[TES] Python import smoke test from ${module_path}"
  PYTHONPATH="${module_path}${PYTHONPATH:+:${PYTHONPATH}}" \
    "${pybin}" -m pytest -q sim/tests
}

usage() {
  cat <<USAGE
Usage:
  ./${SCRIPT_NAME} check [preset|python|python-release]
  ./${SCRIPT_NAME} clean
  ./${SCRIPT_NAME} presets
  ./${SCRIPT_NAME} dev [--demo-run] [--api-port PORT] [--web-port PORT] [--sqlite-path PATH]
  ./${SCRIPT_NAME} sim <command>
  ./${SCRIPT_NAME} api serve [--host HOST] [--port PORT] [--reload] [--store memory|sqlite] [--sqlite-path PATH] [--queue]
  ./${SCRIPT_NAME} api demo-run [--api-url URL] [--steps N] [--symbol SYMBOL] [--seed SEED]
  ./${SCRIPT_NAME} worker run [--worker-id ID] [--poll-interval SECONDS] [--max-jobs N] [--sqlite-path PATH] [--once]
  ./${SCRIPT_NAME} bench [preset] [--json] [--output PATH]
USAGE
}

select_available_port() {
  local host="$1"
  local port="$2"
  local label="$3"
  local scan_limit="${4:-20}"
  local pybin
  if ! pybin="$(resolve_python)"; then
    exit 1
  fi

  "${pybin}" - "$host" "$port" "$label" "$scan_limit" <<'PY'
import socket
import sys

host = sys.argv[1]
port = int(sys.argv[2])
label = sys.argv[3]
scan_limit = int(sys.argv[4])

def is_available(candidate: int) -> tuple[bool, str]:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        try:
            sock.bind((host, candidate))
        except OSError as exc:
            return False, str(exc)
    return True, ""

available, reason = is_available(port)
if available:
    print(port)
    sys.exit(0)

for candidate in range(port + 1, port + scan_limit + 1):
    available, _candidate_reason = is_available(candidate)
    if available:
        print(
            f"[TES] {label} port {port} is not available on {host}; using {candidate} instead. Details: {reason}",
            file=sys.stderr,
        )
        print(candidate)
        sys.exit(0)

print(
    f"[TES] No available {label} port found from {port} through {port + scan_limit} on {host}. "
    f"First failure: {reason}",
    file=sys.stderr,
)
sys.exit(1)
PY
}

wait_for_url() {
  local url="$1"
  local label="$2"
  local timeout_seconds="$3"
  local pybin
  if ! pybin="$(resolve_python)"; then
    exit 1
  fi

  "${pybin}" - "$url" "$label" "$timeout_seconds" <<'PY'
import sys
import time
from urllib.error import HTTPError, URLError
from urllib.request import Request, urlopen

url = sys.argv[1]
label = sys.argv[2]
deadline = time.monotonic() + float(sys.argv[3])
last_error = ""

while time.monotonic() < deadline:
    try:
        request = Request(url, headers={"Accept": "application/json,text/html,*/*"})
        with urlopen(request, timeout=2) as response:
            if 200 <= response.status < 500:
                print(f"[TES] {label} reachable: {url}")
                sys.exit(0)
    except HTTPError as exc:
        if 200 <= exc.code < 500:
            print(f"[TES] {label} reachable: {url}")
            sys.exit(0)
        last_error = f"HTTP {exc.code}"
    except URLError as exc:
        last_error = str(exc.reason)
    except TimeoutError:
        last_error = "timeout"
    time.sleep(1)

print(f"[TES] {label} did not become reachable at {url}: {last_error}", file=sys.stderr)
sys.exit(1)
PY
}

terminate_process_tree() {
  local pid="$1"
  if [[ -z "${pid}" ]]; then
    return 0
  fi

  if is_windows_shell && command -v taskkill >/dev/null 2>&1; then
    taskkill //PID "${pid}" //T //F >/dev/null 2>&1 || true
    return 0
  fi

  kill "${pid}" 2>/dev/null || true
}

run_dev() {
  local api_host="127.0.0.1"
  local api_port="8000"
  local web_host="127.0.0.1"
  local web_port="3000"
  local sqlite_path="runs/tes_runs.sqlite"
  local demo_run=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --demo-run)
        demo_run=1
        shift
        ;;
      --api-port)
        if [[ $# -lt 2 ]]; then
          echo "--api-port requires a port" >&2
          exit 1
        fi
        api_port="$2"
        shift 2
        ;;
      --web-port)
        if [[ $# -lt 2 ]]; then
          echo "--web-port requires a port" >&2
          exit 1
        fi
        web_port="$2"
        shift 2
        ;;
      --sqlite-path)
        if [[ $# -lt 2 ]]; then
          echo "--sqlite-path requires a path" >&2
          exit 1
        fi
        sqlite_path="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --*)
        echo "Unknown dev option: $1" >&2
        exit 1
        ;;
      *)
        echo "Unexpected dev argument: $1" >&2
        exit 1
        ;;
    esac
  done

  api_port="$(select_available_port "${api_host}" "${api_port}" "API")"
  web_port="$(select_available_port "${web_host}" "${web_port}" "dashboard")"

  local script_path
  script_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/${SCRIPT_NAME}"
  local api_url="http://${api_host}:${api_port}"
  local web_url="http://${web_host}:${web_port}"
  local api_pid=""
  local web_pid=""

  cleanup_dev() {
    trap - INT TERM EXIT
    echo "[TES] Shutting down local development processes..."
    if [[ -n "${web_pid}" ]]; then
      terminate_process_tree "${web_pid}"
    fi
    if [[ -n "${api_pid}" ]]; then
      terminate_process_tree "${api_pid}"
    fi
    if [[ -n "${web_pid}" ]]; then
      wait "${web_pid}" 2>/dev/null || true
    fi
    if [[ -n "${api_pid}" ]]; then
      wait "${api_pid}" 2>/dev/null || true
    fi
  }

  trap cleanup_dev INT TERM EXIT

  echo "[TES] Starting API at ${api_url} with SQLite store ${sqlite_path}"
  "${script_path}" api serve --host "${api_host}" --port "${api_port}" --store sqlite --sqlite-path "${sqlite_path}" &
  api_pid="$!"

  echo "[TES] Starting dashboard at ${web_url}"
  (
    cd web
    MSYS_NO_PATHCONV=1 NEXT_PUBLIC_TES_API_URL="/api/tes" TES_API_ORIGIN="${api_url}" \
      npm run dev -- --hostname "${web_host}" --port "${web_port}"
  ) &
  web_pid="$!"

  wait_for_url "${api_url}/health" "API health endpoint" 60 || exit 1
  wait_for_url "${web_url}" "dashboard" 90 || exit 1

  if [[ "${demo_run}" -eq 1 ]]; then
    echo "[TES] Creating persisted demo run through ${api_url}"
    "${script_path}" api demo-run --api-url "${api_url}" || exit 1
  fi

  echo "[TES] Local development stack is ready."
  echo "[TES] API: ${api_url}"
  echo "[TES] Dashboard: ${web_url}"
  echo "[TES] Press Ctrl+C to stop both processes."

  while true; do
    if ! kill -0 "${api_pid}" 2>/dev/null; then
      wait "${api_pid}"
      exit "$?"
    fi
    if ! kill -0 "${web_pid}" 2>/dev/null; then
      wait "${web_pid}"
      exit "$?"
    fi
    sleep 1
  done
}

run_bench() {
  local preset="$(default_preset)"
  local json_output=0
  local output_path=""
  local preset_set=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        json_output=1
        shift
        ;;
      --output)
        if [[ $# -lt 2 ]]; then
          echo "--output requires a path" >&2
          exit 1
        fi
        output_path="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --*)
        echo "Unknown bench option: $1" >&2
        exit 1
        ;;
      *)
        if [[ "${preset_set}" -eq 1 ]]; then
          echo "Unexpected bench argument: $1" >&2
          exit 1
        fi
        preset="$1"
        preset_set=1
        shift
        ;;
    esac
  done

  if [[ "${json_output}" -eq 0 ]]; then
    echo "[TES] Configure preset: ${preset}"
  fi
  if [[ "${json_output}" -eq 1 ]]; then
    cmake --preset "${preset}" >/dev/null
  else
    cmake --preset "${preset}"
  fi
  if [[ "${json_output}" -eq 0 ]]; then
    echo "[TES] Build preset: ${preset}"
    cmake --build --preset "${preset}"
  else
    cmake --build --preset "${preset}" >/dev/null
  fi
  local exe="out/build/${preset}/engine/tes_engine_bench"
  if is_windows_shell; then exe="${exe}.exe"; fi
  if [[ "${json_output}" -eq 0 ]]; then
    echo "[TES] Run benchmark: ${exe}"
  fi

  local helper_args=(--executable "${exe}" --repo-root "$(pwd)" --preset "${preset}")
  if [[ "${json_output}" -eq 1 ]]; then
    helper_args+=(--json)
  fi
  if [[ -n "${output_path}" ]]; then
    helper_args+=(--output "${output_path}")
  fi
  run_python_module sim.tes_benchmarks.cli "${helper_args[@]}"
}

run_python_module() {
  local module="$1"
  shift
  local pybin
  if ! pybin="$(resolve_python)"; then
    exit 1
  fi

  local module_path=""
  local candidate
  for candidate in \
    "out/build/debug-ninja-python/engine" \
    "out/build/release-ninja-python/engine" \
    "out/build/release-msvc-python/engine/Release"
  do
    if [[ -d "${candidate}" ]]; then
      module_path="${candidate}"
      break
    fi
  done

  local SCRIPT_DIR
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  export PYTHONPATH="${SCRIPT_DIR}:${PYTHONPATH:-}"
  if [[ -n "${module_path}" ]]; then
    export PYTHONPATH="${module_path}:${PYTHONPATH}"
  fi

  "${pybin}" -m "${module}" "$@"
}

run_sim_cli() {
  run_python_module sim.tes_cli.cli "$@"
}

run_api_cli() {
  run_python_module sim.api.main "$@"
}

run_worker_cli() {
  run_python_module sim.api.execution.worker "$@"
}

main() {
  local cmd="${1:-}"
  local arg="${2:-}"

  case "$cmd" in
    check)
      case "$arg" in
        "")
          run_core_check
          ;;
        python)
          run_python_check "$(python_preset)" "$(is_windows_shell && echo Release || true)"
          ;;
        python-release)
          if is_windows_shell; then
            run_python_check "release-msvc-python" "Release"
          else
            run_python_check "debug-ninja-python"
          fi
          ;;
        *)
          run_core_check "$arg"
          ;;
      esac
      ;;
    clean)
      echo "[TES] Remove build output: out/build"
      rm -rf out/build
      ;;
    presets)
      echo "[TES] List CMake presets"
      cmake --list-presets
      ;;
    dev)
      shift
      run_dev "$@"
      ;;
    sim)
      run_sim_cli "$@"
      ;;
    api)
      shift
      run_api_cli "$@"
      ;;
    worker)
      shift
      run_worker_cli "$@"
      ;;
    bench)
      shift
      run_bench "$@"
      ;;
    ""|-h|--help|help)
      usage
      ;;
    *)
      echo "Unknown command: ${cmd}" >&2
      usage >&2
      exit 1
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
