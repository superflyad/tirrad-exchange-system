# TES dashboard local environment
#
# The dashboard development server assumes Next.js runs on http://localhost:3000.
# The TES API development server assumes FastAPI runs on http://127.0.0.1:8000.
#
# NEXT_PUBLIC_TES_API_URL is the single canonical dashboard API setting used by
# both the frontend API client and next.config.ts rewrites.
#
# Recommended local default: keep browser traffic same-origin through the
# Next.js proxy at /api/tes. The proxy forwards to http://127.0.0.1:8000.
NEXT_PUBLIC_TES_API_URL=/api/tes

# If you intentionally bypass the Next.js proxy, point the dashboard directly at
# an API origin that allows browser requests from the dashboard origin.
# NEXT_PUBLIC_TES_API_URL=http://127.0.0.1:8000
